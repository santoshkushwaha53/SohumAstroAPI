# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/sohum_astro?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Auth / API Keys ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-minimum-32-chars
API_KEY_HEADER=x-api-key
MASTER_API_KEY=dev-master-key-change-me

# ── Swiss Ephemeris ───────────────────────────────────────────────────────────
# Leave blank to use bundled Moshier algorithm (no file download needed)
EPHE_PATH=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── BullMQ ───────────────────────────────────────────────────────────────────
BULL_CONCURRENCY=5

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
